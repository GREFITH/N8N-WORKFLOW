    {
      "parameters": {
        "jsCode": "// ══════════════════════════════════════════════════════\n// EXTRACT ATTACHMENTS — Historical Outlook Scanner v2.0\n// Outlook getAll (downloadAttachments=ON) provides binary\n// as attachment_0, attachment_1 etc.\n// Binary key preserved as-is so Recover node can read it back.\n// ══════════════════════════════════════════════════════\n\nconst subject    = $json.subject || '';\nconst receivedAt = $json.receivedDateTime || $json.createdDateTime || '';\nconst messageId  = $json.id || '';\n\nconst senderName  = $json.from?.emailAddress?.name    || '';\nconst senderAddr  = $json.from?.emailAddress?.address || '';\nconst sender      = senderName ? `${senderName} <${senderAddr}>` : senderAddr;\nconst senderEmail = senderAddr;\n\nfunction parseFileSize(raw) {\n  if (!raw) return 0;\n  if (typeof raw === 'number') return raw;\n  const s = String(raw).trim();\n  const num = parseFloat(s);\n  if (isNaN(num)) return 0;\n  if (s.match(/gb/i)) return num * 1073741824;\n  if (s.match(/mb/i)) return num * 1048576;\n  if (s.match(/kb/i)) return num * 1024;\n  return num;\n}\n\nconst results = [];\nconst binaryKeys = Object.keys($binary || {}).filter(k => k.startsWith('attachment_'));\n\nif (binaryKeys.length === 0) return [];\n\nfor (const key of binaryKeys) {\n  const att = $binary[key];\n  results.push({\n    json: {\n      filename:        att.fileName || att.name || key,\n      mimeType:        att.mimeType || '',\n      fileSize:        parseFileSize(att.fileSize || att.size || 0),\n      fileSizeRaw:     String(att.fileSize || '0'),\n      messageId,\n      sender,\n      senderEmail,\n      subject,\n      receivedAt,\n      source_type:     'EMAIL_HISTORICAL',\n      source_provider: 'OUTLOOK',\n      binaryKey:       key          // ← store key so Recover node can find it\n    },\n    binary: { data: att }           // ← normalise to 'data' for downstream nodes\n  });\n}\n\nreturn results;\n"
      },
      "id": "0ba543c8-b056-45c0-a33c-7444d61372e0",
      "name": "⚙️ Code — Extract Outlook Attachments",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        64
      ]
    },
