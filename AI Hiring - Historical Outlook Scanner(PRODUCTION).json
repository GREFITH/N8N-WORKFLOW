    {
      "parameters": {
        "jsCode": "// ══════════════════════════════════════════════════════\n// RECOVER BINARY + META BEFORE WEBHOOK\n// Sheets Lookup drops binary. Recover from Hash node.\n// ══════════════════════════════════════════════════════\n\nconst hashItem = $('🔑 Code — Generate File Hash').item;\nconst meta = hashItem.json;\n\nif (!meta || !meta.filename) {\n  throw new Error('Could not retrieve metadata from hash node. Check node name matches exactly.');\n}\n\nconst binary = hashItem.binary || {};\n\nif (Object.keys(binary).length === 0) {\n  throw new Error('No binary found in hash node. Attachment may not have downloaded.');\n}\n\nreturn [{\n  json: {\n    filename:        meta.filename,\n    mimeType:        meta.mimeType,\n    fileSize:        meta.fileSize,\n    sender:          meta.sender,\n    senderEmail:     meta.senderEmail    || '',\n    subject:         meta.subject,\n    receivedAt:      meta.receivedAt,\n    source_type:     meta.source_type     || 'EMAIL_HISTORICAL',\n    source_provider: meta.source_provider || 'OUTLOOK',\n    mailbox:         meta.mailbox         || '',\n    fileHash:        meta.fileHash,\n    messageId:       meta.messageId       || ''\n  },\n  binary: binary\n}];\n"
      },
