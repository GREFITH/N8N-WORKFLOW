    {
      "parameters": {
        "jsCode": "// ══════════════════════════════════════════════════════\n// GENERATE FILE HASH — Historical Outlook Scanner\n// Uses SAME djb2 algorithm + ol_ prefix as real-time Outlook Monitor\n// → If real-time monitor already processed this email = DUPLICATE_SKIPPED\n// ══════════════════════════════════════════════════════\n\nfunction djb2Hash(str) {\n  let hash = 5381;\n  for (let i = 0; i < str.length; i++) {\n    hash = ((hash << 5) + hash) + str.charCodeAt(i);\n    hash = hash & hash;\n  }\n  return Math.abs(hash).toString(16);\n}\n\nconst filename  = $json.filename  || 'unknown';\nconst fileSize  = String($json.fileSize  || '0');\nconst mimeType  = $json.mimeType  || '';\nconst sender    = $json.sender    || '';\n\nconst hashInput = `${filename}|${fileSize}|${mimeType}|${sender}`;\nconst fileHash  = 'ol_' + djb2Hash(hashInput) + '_' + fileSize;\n\nreturn [{\n  json: { ...$json, fileHash: fileHash },\n  binary: $binary\n}];\n"
      },
