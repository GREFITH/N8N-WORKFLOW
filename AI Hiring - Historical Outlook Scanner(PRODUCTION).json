      "id": "c1583e80-3e29-4234-8e5a-36a0e8ee3013",
      "name": "🔄 Loop — Process Each Email",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        208,
        568
      ]
